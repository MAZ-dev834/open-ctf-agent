# Copy this file to a local env file and adjust as needed.
# Event-specific credentials should live in your own local event directory.

# Optional opencode runtime
OPENCODE_ATTACH_URL=http://127.0.0.1:4096
OPENCODE_DB=~/.local/share/opencode/opencode.db
OPENCODE_CONFIG=.opencode/opencode.json

# Optional OpenAI-compatible model API
# Used as fallback by runtime_config for model-serving endpoints.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=YOUR_API_KEY
OPENAI_MODEL=gpt-4.1-mini

# Optional pipeline model routing
# CTF_MODEL: default model used by ctfd_pipeline.py when --model is omitted
# CTF_FIRST_BLOOD_MODEL: preferred model for --first-blood-mode
CTF_MODEL=openai/gpt-4.1-mini
CTF_FIRST_BLOOD_MODEL=openai/gpt-4.1

# Optional local VLM runtime
CTF_VLM_BASE_URL=http://127.0.0.1:1234/v1
CTF_VLM_MODEL=qwen3.5-2b
CTF_VLM_API_KEY=EMPTY
